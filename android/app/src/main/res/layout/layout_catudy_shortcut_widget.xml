<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_shortcut_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Action Section -->
    <LinearLayout
        android:id="@+id/widget_shortcut_action_btn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/widget_shortcut_play_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_play"
            android:tint="#26A69A"
            android:background="@android:drawable/toast_frame"
            android:padding="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/widget_shortcut_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ders"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hızlı Odak başlat"
                android:textColor="#A5A1B2"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Session Status Section -->
    <TextView
        android:id="@+id/widget_shortcut_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:text="Hazır"
        android:textColor="#A5A1B2"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@android:drawable/toast_frame" />
</LinearLayout>
