<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_streak_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:id="@+id/widget_streak_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seri"
        android:textColor="#A5A1B2"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_streak_days"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_streak_goal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/45 dk"
        android:textColor="#A5A1B2"
        android:textSize="11sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/widget_streak_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_marginTop="10dp"
        android:max="100"
        android:progress="0"
        android:progressBackgroundTint="#3A2F4C"
        android:progressTint="#FF8A80" />
</LinearLayout>
