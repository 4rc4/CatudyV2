<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- Left side: Mascot Avatar and Name -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="4"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="12dp">

        <ImageView
            android:id="@+id/widget_pet_avatar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Pet Mascot"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/widget_pet_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Mochi"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Right side: Stats Bars & Streak -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="5"
        android:orientation="vertical">

        <!-- Stat 1: Mood -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_pet_mood_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mod"
                android:textColor="#A5A1B2"
                android:textSize="11sp"
                android:textStyle="bold" />
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/widget_pet_mood_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
        <ProgressBar
            android:id="@+id/widget_pet_mood_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp"
            android:max="100"
            android:progress="100"
            android:progressBackgroundTint="#3A2F4C"
            android:progressTint="#FF8A80" />

        <!-- Stat 2: Hunger -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_pet_hunger_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Açlık"
                android:textColor="#A5A1B2"
                android:textSize="11sp"
                android:textStyle="bold" />
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/widget_pet_hunger_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
        <ProgressBar
            android:id="@+id/widget_pet_hunger_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp"
            android:max="100"
            android:progress="100"
            android:progressBackgroundTint="#3A2F4C"
            android:progressTint="#FFD54F" />

        <!-- Stat 3: Energy -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_pet_energy_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enerji"
                android:textColor="#A5A1B2"
                android:textSize="11sp"
                android:textStyle="bold" />
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/widget_pet_energy_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
        <ProgressBar
            android:id="@+id/widget_pet_energy_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp"
            android:max="100"
            android:progress="100"
            android:progressBackgroundTint="#3A2F4C"
            android:progressTint="#26A69A" />

        <!-- Streak Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/btn_star_big_on"
                android:tint="#FF8A80" />
            <TextView
                android:id="@+id/widget_pet_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0 Gün Serisi"
                android:textColor="#A5A1B2"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
